{
  "lastChangelogVersion": "0.78.1",
  "defaultProvider": "google",
  "defaultModel": "gemini-3.1-flash-lite",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": false,
  "packages": [
    "npm:pi-paster",
    "npm:pi-screenshots-picker",
    "npm:pi-smart-fetch",
    "npm:pi-subagents",
    "npm:pi-intercom",
    {
      "source": "npm:pi-web-access",
      "extensions": [
        "+index.ts"
      ]
    },
    "npm:pi-animations"
  ],
  "pi-screenshots": {
    "sources": [
      "~/Pictures/Screenshots/"
    ]
  },
  "powerline": {
    "preset": "custom",
    "fixedEditor": true
  },
  "showLastPrompt": true,
  "extensions": [
    "+extensions/adjutant-editor.ts",
    "+extensions/guardrails.ts",
    "+extensions/bash-truncator.ts",
    "+extensions/tool-cache.ts",
    "+extensions/gmail.ts",
    "+extensions/PromptClassifier.ts",
    "+extensions/PromptRouter.ts",
    "+extensions/adjutant-greeting.ts",
    "+extensions/cost-tracker.ts",
"+extensions/first-run.ts",
    "+extensions/session-name-status.ts",
    "+extensions/context-resolver.ts",
    "+extensions/secure-tools.ts",
    "+extensions/tui-dryrun.ts",
    "+extensions/extension-watcher.ts",
    "-extensions/memory-inject.ts"
  ],
  "themes": [
    "-themes/catppuccin-mocha.json",
    "-themes/cyberpunk.json",
    "-themes/dracula.json",
    "-themes/everforest.json",
    "-themes/gruvbox.json",
    "-themes/midnight-ocean.json",
    "-themes/nord.json",
    "-themes/ocean-breeze.json",
    "-themes/rose-pine.json",
    "-themes/synthwave.json",
    "+themes/tokyonight.json"
  ],
  "terminal": {
    "showTerminalProgress": true
  },
  "images": {
    "autoResize": false
  },
  "theme": "tokyonight",
  "quietStartup": true
}
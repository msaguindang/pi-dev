{
  "defaultProvider": "anthropic",
  "defaultModel": "claude-haiku-4-5",
  "defaultThinkingLevel": "medium",
  "hideThinkingBlock": false,
  "packages": [
    "npm:pi-paster",
    "npm:pi-screenshots-picker",
    "npm:pi-smart-fetch",
    "npm:pi-subagents",
    {
      "source": "npm:pi-web-access",
      "extensions": [
        "+index.ts"
      ]
    },
    "npm:pi-animations"
  ],
  "pi-screenshots": {
    "sources": [
      "~/Pictures/Screenshots/"
    ]
  },
  "powerline": {
    "preset": "custom",
    "fixedEditor": true
  },
  "showLastPrompt": true,
  "extensions": [
    "+extensions/adjutant-editor.ts",
    "+extensions/guardrails.ts",
    "+extensions/harness-audit-gate.ts",
    "+extensions/bash-truncator.ts",
    "+extensions/tool-cache.ts",
    "+extensions/gmail.ts",
    "+extensions/adjutant-greeting.ts",
    "+extensions/cost-tracker.ts",
    "+extensions/first-run.ts",
    "+extensions/session-name-status.ts",
    "+extensions/context-resolver.ts",
    "+extensions/tui-dryrun.ts",
    "+extensions/extension-watcher.ts",
    "-extensions/prompt-classifier.ts",
    "-extensions/prompt-router.ts"
  ],
  "themes": [
    "-themes/catppuccin-mocha.json",
    "-themes/cyberpunk.json",
    "-themes/dracula.json",
    "-themes/everforest.json",
    "-themes/gruvbox.json",
    "-themes/midnight-ocean.json",
    "-themes/nord.json",
    "-themes/ocean-breeze.json",
    "-themes/rose-pine.json",
    "-themes/synthwave.json",
    "+themes/tokyonight.json"
  ],
  "terminal": {
    "showTerminalProgress": true
  },
  "images": {
    "autoResize": false
  },
  "subagents": {
    "_comment": "agentOverrides is the canonical mechanism for model/thinking pins on builtin agents. The harness does NOT use it — local agents/*.md files are used instead because they support systemPromptMode: replace, defaultReads, output, and defaultProgress, which agentOverrides does not. Use agentOverrides only for lightweight model or thinking overrides that do not require a custom system prompt.",
    "agentOverrides": {
      "researcher": { "model": "google/gemini-3.1-pro-preview-customtools", "thinking": "medium" },
      "context-builder": { "model": "anthropic/claude-sonnet-4-6", "thinking": "medium" }
    }
  },
  "theme": "tokyonight",
  "quietStartup": true
}
